{
	"name": "msw-design-system",
	"private": true,
	"scripts": {
		"build": "pnpm -r run build",
		"typecheck": "pnpm -r run typecheck",
		"dev": "pnpm --filter @modernsoftwareworks/docs run dev",
		"lint": "vp lint .",
