{
  "name": "msw-design-system",
  "private": true,
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "dev": "pnpm --filter @modernsoftwareworks/docs run dev",
    "lint": "vp lint .",
    "test": "vp test run",
    "test:a11y": "playwright test --project=quality-light --project=quality-dark",
    "test:bundle": "node scripts/quality/bundle-budget.mjs",
    "test:lighthouse": "lhci autorun --config=lighthouserc.json",
    "test:react-doctor": "node scripts/quality/react-doctor-gate.mjs",
    "test:react-scan": "node scripts/check-react-scan.mjs && playwright test --project=react-scan",
    "test:quality": "pnpm run test:bundle && pnpm run test:react-scan && pnpm run test:a11y && pnpm run test:lighthouse && pnpm run test:react-doctor",
    "format": "vp fmt",
    "release": "pnpm build && pnpm changeset publish",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@changesets/cli": "^2.31.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "jsdom": "^29.1.1",
    "react-doctor": "^0.8.3",
    "react-scan": "^0.5.7",
    "typescript": "~6.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.7.0"
}
