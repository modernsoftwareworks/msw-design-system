{
  "name": "msw-design-system",
  "private": true,
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "dev": "pnpm --filter @modernsoftwareworks/docs run dev",
    "lint": "vp lint .",
    "test": "vp test run",
    "test:a11y": "playwright test",
    "test:bundle": "node scripts/check-bundle-budget.mjs",
    "test:lighthouse": "lhci autorun",
    "test:react-doctor": "node scripts/check-react-doctor.mjs",
    "test:react-scan": "node scripts/check-react-scan.mjs",
    "test:quality": "pnpm run test:bundle && pnpm run test:react-scan && pnpm run test:a11y && pnpm run test:lighthouse && pnpm run test:react-doctor",
    "format": "vp fmt",
    "release": "pnpm build && pnpm changeset publish",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@changesets/cli": "^2.31.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.54.2",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.7.0"
}
